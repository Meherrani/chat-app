# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Custom Search — https://developers.google.com/custom-search/v1/introduction
# 1. Create an API key in Google Cloud Console with "Custom Search API" enabled.
# 2. Create a Programmable Search Engine at https://programmablesearchengine.google.com/
#    and set it to "Search the entire web". Copy its "Search engine ID" (cx).
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
